generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  CONTENT_MANAGER
  MODERATOR
  SUPPORT
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  username   String     @unique
  password   String
  role       String     @default("USER")
  adminRole  AdminRole?
  firstName  String
  lastName   String
  title      String?
  bio        String?
  avatar     String?
  company    String?
  location   String?
  website    String?
  skills     String[]   @default([])
  experience Json?
  education  Json?
  portfolio  Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  posts              Post[]
  comments           Comment[]
  likes              Like[]
  savedPosts         SavedPost[]
  reports            Report[]                 @relation("ReportReporter")
  resolvedReports    Report[]                 @relation("ReportResolver")
  nameVotes          NameVote[]
  opportunityReviews OpportunityReview[]
  adminLogs          AdminLog[]               @relation("AdminLogActor")
  followers          Follow[]                 @relation("UserFollowers")
  following          Follow[]                 @relation("UserFollowing")
  opportunities      FreelanceOpportunity[]   @relation("OpportunityAuthor")
  applications       OpportunityApplication[]
  organizedEvents    Event[]                  @relation("EventOrganizer")
  eventAttendances   EventAttendee[]
  notifications      Notification[]           @relation("NotificationRecipient")
  notificationActs   Notification[]           @relation("NotificationActor")
  conversationsA     Conversation[]           @relation("ConversationParticipantA")
  conversationsB     Conversation[]           @relation("ConversationParticipantB")
  sentMessages       Message[]                @relation("MessageSender")
}

model Post {
  id        String   @id @default(cuid())
  content   String
  imageUrl  String?
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    Like[]
  saves    SavedPost[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model SavedPost {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model FreelanceOpportunity {
  id           String   @id @default(cuid())
  title        String
  company      String
  description  String
  skills       String[] @default([])
  budget       String
  location     String
  remote       Boolean  @default(true)
  contractType String   @default("Mission")
  authorId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  author       User                     @relation("OpportunityAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  applications OpportunityApplication[]
  reviews      OpportunityReview[]
}

model OpportunityApplication {
  id            String   @id @default(cuid())
  message       String
  opportunityId String
  applicantId   String
  createdAt     DateTime @default(now())

  opportunity FreelanceOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  applicant   User                 @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, applicantId])
}

model OpportunityReview {
  id            String   @id @default(cuid())
  rating        Int
  comment       String
  opportunityId String
  reviewerId    String
  createdAt     DateTime @default(now())

  opportunity FreelanceOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  reviewer    User                 @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, reviewerId])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String
  location    String
  startsAt    DateTime
  endsAt      DateTime?
  online      Boolean   @default(false)
  url         String?
  organizerId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organizer User            @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  attendees EventAttendee[]
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  message     String
  link        String?
  read        Boolean  @default(false)
  recipientId String
  actorId     String?
  createdAt   DateTime @default(now())

  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, read, createdAt])
  @@index([actorId])
}

model Conversation {
  id             String   @id @default(cuid())
  participantAId String
  participantBId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participantA User      @relation("ConversationParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB User      @relation("ConversationParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([participantAId, participantBId])
  @@index([participantAId])
  @@index([participantBId])
}

model Message {
  id             String   @id @default(cuid())
  content        String
  read           Boolean  @default(false)
  conversationId String
  senderId       String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Report {
  id         String    @id @default(cuid())
  targetType String
  targetId   String
  reason     String
  status     String    @default("OPEN")
  reporterId String
  resolverId String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  reporter User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver User? @relation("ReportResolver", fields: [resolverId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([status, createdAt])
}

model NameVote {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([name, userId])
}

model SiteSettings {
  id              String   @id @default("default")
  siteName        String   @default("NexusIT")
  logoUrl         String?
  primaryColor    String   @default("#4f8ef7")
  accentColor     String   @default("#2dd4a0")
  backgroundColor String   @default("#0a0a0d")
  fontFamily      String   @default("Inter")
  seoTitle        String   @default("NexusIT")
  seoDescription  String   @default("Réseau professionnel IT")
  socialLinks     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StaticPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  status    String   @default("DRAFT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blocks PageBlock[]
}

model PageBlock {
  id        String   @id @default(cuid())
  pageId    String
  type      String
  order     Int
  content   Json
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page StaticPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, order])
}

model AdminLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  actor User? @relation("AdminLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}
